{
  "app": "psat-bench",
  "url": "https://psat-bench.fly.dev",
  "address": "0x308861A430be4cce5502d0A12724771Fc6DaF216",
  "label_prefix": "etherfi-lp-split",
  "warm_wait_s": 30,
  "poll_interval": 1.0,
  "samples_per_run": 1,
  "force": true,
  "follow_all_jobs": true,
  "wipe_db_between_runs": true,
  "subprocess_timeout_s": 7200,
  "_note": "Split-worker test (todo #2 + codex revision). Requires deploying fly-bench-split.toml first which defines workers-heavy (static+resolution+policy) and workers-light (everything else) process groups. Matrix scales each group independently per run.",
  "runs": [
    {
      "label": "heavy-perf-light-shared",
      "groups": {
        "workers-heavy": {
          "vm_size": "performance-2x",
          "memory_mb": 4096,
          "count": 1
        },
        "workers-light": {
          "vm_size": "shared-cpu-2x",
          "memory_mb": 1024,
          "count": 1
        }
      }
    },
    {
      "label": "heavy-shared-light-shared",
      "groups": {
        "workers-heavy": {
          "vm_size": "shared-cpu-2x",
          "memory_mb": 2048,
          "count": 1
        },
        "workers-light": {
          "vm_size": "shared-cpu-1x",
          "memory_mb": 1024,
          "count": 1
        }
      }
    }
  ]
}
