{
  "app": "psat-bench",
  "url": "https://psat-bench.fly.dev",
  "address": "0x83bc649fcdb2c8da146b2154a559ddedf937ef12",
  "label_prefix": "stat-vm-mat",
  "warm_wait_s": 30,
  "poll_interval": 2.0,
  "samples_per_run": 1,
  "force": true,
  "follow_all_jobs": true,
  "wipe_db_between_runs": true,
  "subprocess_timeout_s": 9000,
  "_note": "5 untested combinations of (PSAT_STATIC_WORKERS, VM size). Submitting etherfi LP impl directly (cascades into 22 jobs). 2hr subprocess ceiling per run since some configs may grind. Reference points: 2s+perf-2x = 698-780s ✓; 2s+shared-2x = wedges.",
  "runs": [
    {
      "label": "1s_perf-1x_2gb",
      "vm_size": "performance-1x",
      "memory_mb": 2048,
      "count": 1,
      "env": { "PSAT_STATIC_WORKERS": "1" }
    },
    {
      "label": "2s_perf-1x_2gb",
      "vm_size": "performance-1x",
      "memory_mb": 2048,
      "count": 1,
      "env": { "PSAT_STATIC_WORKERS": "2" }
    },
    {
      "label": "3s_perf-2x_4gb",
      "vm_size": "performance-2x",
      "memory_mb": 4096,
      "count": 1,
      "env": { "PSAT_STATIC_WORKERS": "3" }
    },
    {
      "label": "4s_perf-2x_4gb",
      "vm_size": "performance-2x",
      "memory_mb": 4096,
      "count": 1,
      "env": { "PSAT_STATIC_WORKERS": "4" }
    },
    {
      "label": "1s_shared-2x_2gb",
      "vm_size": "shared-cpu-2x",
      "memory_mb": 2048,
      "count": 1,
      "env": { "PSAT_STATIC_WORKERS": "1" }
    }
  ]
}
