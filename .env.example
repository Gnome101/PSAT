DATABASE_URL=postgresql://psat:psat@localhost:5433/psat
TEST_DATABASE_URL=postgresql://psat:psat@localhost:5433/psat_test

# Required in prod. Random high-entropy string sent in the X-PSAT-Admin-Key
# header for every non-GET API call. Workers and the admin UI must use it.
PSAT_ADMIN_KEY=

# Comma-separated list of origins allowed to call the API from a browser.
PSAT_SITE_ORIGIN=

ETHERSCAN_API_KEY=
ETH_RPC=
ENVIO_API_TOKEN=
NVIDIA_API_KEY=
TAVILY_API_KEY=
OPEN_ROUTER_KEY=

# Object storage for artifact bodies (S3-compatible).
# Local dev: minio service in docker-compose.yml.
# Production: Fly Tigris (`fly storage create`).
# Leave all four blank to fall back to inline Postgres storage (legacy mode).
ARTIFACT_STORAGE_ENDPOINT=http://localhost:9000
ARTIFACT_STORAGE_BUCKET=psat-artifacts
ARTIFACT_STORAGE_ACCESS_KEY=psat-minio
ARTIFACT_STORAGE_SECRET_KEY=psat-minio-secret

# Test bucket — used by tests/test_artifact_storage_integration.py.
TEST_ARTIFACT_STORAGE_ENDPOINT=http://localhost:9000
TEST_ARTIFACT_STORAGE_BUCKET=psat-artifacts-test
TEST_ARTIFACT_STORAGE_ACCESS_KEY=psat-minio
TEST_ARTIFACT_STORAGE_SECRET_KEY=psat-minio-secret

# Rate limits
ETHERSCAN_RATE_LIMIT=5
RPC_RATE_LIMIT=15
PROTOCOL_SCAN_INTERVAL=120
PROTOCOL_POLL_INTERVAL=300
PROTOCOL_TVL_INTERVAL=3600
