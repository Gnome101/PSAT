# Local dev uses the docker-compose postgres; Fly/Neon uses two Neon URLs.
# Runtime: pooled (-pooler.) URL — app/workers/monitor open pooled connections.
# Release/migrations: direct URL — alembic cannot run through pgbouncer transaction mode.
DATABASE_URL=postgresql://psat:psat@localhost:5433/psat
# DATABASE_URL=postgresql://<user>:<pw>@ep-xxx-pooler.us-east-1.aws.neon.tech/psat?sslmode=require
# DATABASE_URL_DIRECT=postgresql://<user>:<pw>@ep-xxx.us-east-1.aws.neon.tech/psat?sslmode=require
TEST_DATABASE_URL=postgresql://psat:psat@localhost:5433/psat_test
ETHERSCAN_API_KEY=
ETH_RPC=
ENVIO_API_TOKEN=
NVIDIA_API_KEY=
TAVILY_API_KEY=
OPEN_ROUTER_KEY=

# Rate limits
ETHERSCAN_RATE_LIMIT=5
RPC_RATE_LIMIT=15
PROTOCOL_SCAN_INTERVAL=120
PROTOCOL_POLL_INTERVAL=300
PROTOCOL_TVL_INTERVAL=3600
